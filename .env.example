# Supabase PostgreSQL (IPv4-only / Pooler para serverless)
DATABASE_URL="postgresql://postgres.xxxx:tu_contraseñas@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:tu_contraseñas@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# Auth.js — secreto para firmar JWT (cambiar en producción)
AUTH_SECRET="cambiar_este_secreto_en_produccion_32chars"

# URL base de la aplicación
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob — para subida de fotos de incidencias (configurar cuando se use)
# BLOB_READ_WRITE_TOKEN="vercel_blob_token_aqui"
